{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/IrfanSadiqRahat/constellation/blob/main/schema/manifest.schema.json",
  "title": "Constellation manifest",
  "type": "object",
  "required": ["version", "updatedAt", "totalAgents", "totalTeams", "teams"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "updatedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "totalAgents": { "type": "integer", "minimum": 1 },
    "totalTeams": { "type": "integer", "minimum": 1 },
    "authoredKeystones": { "type": "integer", "minimum": 0 },
    "teams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "lead", "description", "agents"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,30}$" },
          "name": { "type": "string", "minLength": 1 },
          "lead": { "type": "string" },
          "description": { "type": "string" },
          "agents": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "role", "in", "out"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,40}$" },
                "role": { "type": "string", "minLength": 5, "maxLength": 200 },
                "in": { "type": "string" },
                "out": { "type": "string" },
                "authored": { "type": "boolean" },
                "upstream": { "type": "string", "format": "uri" }
              }
            }
          }
        }
      }
    }
  }
}
